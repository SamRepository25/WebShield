# By default, the frontend uses the built-in Next.js API route at /api/scan.
# No configuration is needed for the app to work on Bolt or Vercel.

# To use the standalone FastAPI backend (e.g. deployed on Render) instead,
# set this to the backend's base URL (without a trailing slash):
# NEXT_PUBLIC_API_URL=https://webshield-api.onrender.com

# For local development with the Python backend running on port 8000:
# BACKEND_URL=http://localhost:8000
